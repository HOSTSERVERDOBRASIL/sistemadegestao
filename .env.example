# ─────────────────────────────────────────────────────────────────────────────
# AtlasX — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Em produção: NODE_ENV=production

# ─── Banco de Dados ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/atlasX
# Com Docker Compose:
# MONGODB_URI=mongodb://atlasX:SENHA@mongo:27017/atlasX?authSource=admin
# Com MongoDB Atlas:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/atlasX?retryWrites=true

# ─── JWT — OBRIGATÓRIO ────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_ISSO_POR_UM_SECRET_FORTE_DE_64_CHARS_OU_MAIS
JWT_EXPIRES_IN=8h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaço)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Em produção:
# ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# ─── Upload de arquivos ───────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Ponte website-main -> AtlasX ────────────────────────────────────────────
# Use o mesmo valor configurado como ATLAS_API_KEY no backend da loja.
# Gere uma chave longa e aleatória; as rotas recusam chamadas se ficar vazio.
GESTAO_BRIDGE_API_KEY=

# ─── Consulta cadastral Serpro + ViaCEP ──────────────────────────────────────
# Token Basic fornecido pelo Serpro (base64 de client_id:client_secret).
# O nome legado BASECTOKEN_SERPRO também é aceito, mas prefira este.
SERPRO_BASIC_TOKEN=
SERPRO_TIMEOUT=15000
VIACEP_TIMEOUT=8000

# ─── Integração Atlas ERP ↔ Atlas CLM ────────────────────────────────────────
CLM_BASE_URL=
CLM_API_TOKEN=
CLM_HMAC_SECRET=
CLM_TIMEOUT=20000

# ─── Docker MongoDB (usado pelo docker-compose) ───────────────────────────────
MONGO_USER=atlasX
MONGO_PASSWORD=TROQUE_ISSO_POR_UMA_SENHA_FORTE

# ─── Efi Bank (PIX + Boleto) ─────────────────────────────────────────────────
# Obtenha em: https://dev.efipay.com.br → Aplicações → Nova Aplicação
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# true = sandbox (homologação), false = produção real
EFI_SANDBOX=true
# Chave PIX cadastrada na conta Efi (CPF, CNPJ, email, telefone ou aleatória)
EFI_PIX_KEY=
# Certificado .p12 baixado do painel Efi Bank (obrigatório para PIX produção)
EFI_CERT_PATH=./certs/certificado.p12
# Alternativa para deploy sem arquivo físico (não configure as duas opções)
# EFI_CERT_BASE64=
# URL HTTPS pública desta API. A Efí acrescenta /pix; o sistema trata ambos os caminhos.
EFI_WEBHOOK_URL=https://api.seudominio.com/cobrancas/webhook/efi
# Hash aleatório enviado como query string na URL registrada — obrigatório sem mTLS
EFI_WEBHOOK_SECRET=
# true somente quando o proxy/servidor validar o certificado cliente da Efí
EFI_WEBHOOK_VALIDATE_MTLS=false

# ─── Tiny ERP / Olist ────────────────────────────────────────────────────────
# Obtenha em: Olist (TinyERP) → Configurações → Integrações → API → Token
# MESMO token usado para sincronização de pedidos E emissão de NF-e (SEFAZ)
TINY_TOKEN=
# Timeout de chamadas à API Tiny em milissegundos
TINY_TIMEOUT=15000
# Secret para autenticar webhook Tiny → configure no painel e copie aqui
TINY_WEBHOOK_SECRET=

# ─── Olist Fretes (cotação de envio) ─────────────────────────────────────────
# Identificador do parceiro Olist (número fornecido pela Olist)
OLIST_PARTNER_ID=9700
# Token Bearer para autenticação na API de cotação de fretes
OLIST_TOKEN=
# Timeout das chamadas em milissegundos
OLIST_TIMEOUT=15000

# ─── Banco do Brasil (extrato + conciliação) ──────────────────────────────────
# Obtenha em: https://developers.bb.com.br → Minhas Aplicações → Nova Aplicação
BB_CLIENT_ID=
BB_CLIENT_SECRET=
# Número do convênio, agência e conta corrente PJ
BB_CONVENIO=
BB_AGENCIA=
BB_CONTA=
# true = sandbox BB, false = produção
BB_SANDBOX=true
BB_TIMEOUT=20000

# ─── Bradesco (extrato + conciliação) ────────────────────────────────────────
# Obtenha em: https://developers.bradesco.com.br
BRADESCO_CLIENT_ID=
BRADESCO_CLIENT_SECRET=
BRADESCO_CNPJ=
BRADESCO_AGENCIA=
BRADESCO_CONTA=
BRADESCO_SANDBOX=true
BRADESCO_TIMEOUT=20000

# ─── Frontend (Vite) — apenas para build de produção ─────────────────────────
# Se a API e o frontend ficarem em domínios diferentes:
# VITE_API_BASE_URL=https://api.seudominio.com.br
# Se ficarem no mesmo domínio (nginx proxy /api → backend), deixe em branco.

# ─── Portal por Token (acesso externo sem login) ──────────────────────────────
# URL base pública do frontend (usada para montar o link /portal/:token nos e-mails)
PORTAL_BASE_URL=https://seudominio.com.br

# ─── E-mail transacional ──────────────────────────────────────────────────────
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=
SMTP_FROM="AtlasX <noreply@seudominio.com.br>"
